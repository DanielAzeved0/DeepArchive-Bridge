version: '3.8'

services:
  postgres:
    image: postgres:16-alpine
    container_name: deeparchive-postgres
    environment:
      POSTGRES_USER: deeparchive_user
      POSTGRES_PASSWORD: secure_password_123
      POSTGRES_DB: deeparchive_db
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - deeparchive-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U deeparchive_user"]
      interval: 10s
      timeout: 5s
      retries: 5

volumes:
  postgres_data:

networks:
  deeparchive-network:
